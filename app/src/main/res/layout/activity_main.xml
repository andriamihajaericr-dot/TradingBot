<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:padding="16dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🤖 Trading Bot" android:textSize="26sp" android:textStyle="bold"
            android:textColor="#f5c842" android:gravity="center" android:layout_marginBottom="4dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Notifications → Claude AI → Buy/Sell" android:textSize="12sp"
            android:textColor="#888888" android:gravity="center" android:layout_marginBottom="20dp"/>

        <TextView android:id="@+id/statusText"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🔴 Bot inactif" android:textSize="16sp" android:textColor="#ffffff"
            android:background="#161b22" android:padding="14dp" android:layout_marginBottom="16dp"/>

        <Switch android:id="@+id/botSwitch"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="  Activer le Bot" android:textColor="#ffffff" android:textSize="18sp"
            android:layout_gravity="center" android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="⚙️ Clés API" android:textColor="#f5c842" android:textSize="14sp"
            android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/apiKeyInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Clé Claude API (sk-ant-...)" android:inputType="textPassword"
            android:textColor="#ffffff" android:textColorHint="#555555"
            android:background="#161b22" android:padding="12dp" android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/telegramTokenInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Token Telegram Bot (@BotFather)" android:inputType="textPassword"
            android:textColor="#ffffff" android:textColorHint="#555555"
            android:background="#161b22" android:padding="12dp" android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/telegramChatIdInput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Chat ID Telegram (@userinfobot)" android:inputType="number"
            android:textColor="#ffffff" android:textColorHint="#555555"
            android:background="#161b22" android:padding="12dp" android:layout_marginBottom="12dp"/>

        <Button android:id="@+id/saveBtn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="💾 Sauvegarder les clés" android:backgroundTint="#238636"
            android:textColor="#ffffff" android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/permBtn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🔔 Activer Permission Notifications" android:backgroundTint="#da3633"
            android:textColor="#ffffff" android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/testBtn"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🧪 Tester l'analyse" android:backgroundTint="#1f6feb"
            android:textColor="#ffffff" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="📋 Journal" android:textColor="#f5c842" android:textSize="13sp"
            android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <TextView android:id="@+id/logText"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="En attente de notifications..." android:textColor="#8b949e"
            android:textSize="12sp" android:background="#161b22" android:padding="12dp"
            android:fontFamily="monospace"/>
    </LinearLayout>
</ScrollView>
